# PanWatch local environment template
# Copy this file to `.env` and fill in your own values.

# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD=
JWT_SECRET=

# App
TZ=Asia/Shanghai
DATA_DIR=./data
HTTP_PROXY=

# Default AI fallback
# Used when you have not configured an AI service/model in the UI.
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=
AI_MODEL=glm-4

# News sources
# Used as fallback when the Tushare datasource config token is empty.
TUSHARE_TOKEN=

# Optional
PLAYWRIGHT_SKIP_BROWSER_INSTALL=0
